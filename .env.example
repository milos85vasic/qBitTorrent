# qBitTorrent Search Plugins Configuration
# Copy this file to .env and fill in your credentials
#
# IMPORTANT: Never commit this file with real credentials!
# This file is ignored by git (.gitignore)
#
# Alternative credential storage methods:
#   1. Export in ~/.bashrc: export RUTRACKER_USERNAME="your_username"
#   2. Create ~/.qbit.env with your credentials
#   3. Use Docker/Podman secrets management

# =============================================================================
# RuTracker.org Configuration (REQUIRED)
# =============================================================================
# Biggest Russian torrent tracker - Registration required
# Register at: https://rutracker.org/forum/profile.php?mode=register

# Required: RuTracker Login Credentials
# Supports: RUTRACKER_USERNAME or RUTRACKER_USER
# Supports: RUTRACKER_PASSWORD or RUTRACKER_PASS
RUTRACKER_USERNAME=your_rutracker_username
RUTRACKER_PASSWORD=your_rutracker_password

# Optional: Custom RuTracker Mirrors (comma-separated)
# If not set, default mirrors will be used
# Default: https://rutracker.org,https://rutracker.net,https://rutracker.nl
# RUTRACKER_MIRRORS=https://rutracker.org,https://rutracker.net

# =============================================================================
# Rutor.info Configuration (OPTIONAL - No Login Required)
# =============================================================================
# Popular free Russian torrent tracker - NO registration required!
# Works without any credentials

# Optional: Use magnet links instead of .torrent files
# Magnet links work in desktop qBittorrent but may not work in WebUI
# Default: false
RUTOR_USE_MAGNET=false

# Optional: Proxy Configuration
# Enable proxy if you need to access Rutor through a proxy
RUTOR_PROXY_ENABLED=false

# HTTP/HTTPS Proxy URLs (if RUTOR_PROXY_ENABLED=true)
# Format: http://proxy.example.com:8080 or socks5://127.0.0.1:9050
# RUTOR_HTTP_PROXY=http://proxy.example.com:8080
# RUTOR_HTTPS_PROXY=http://proxy.example.com:8080

# Optional: Custom User-Agent
# Default: Mozilla/5.0 (X11; Linux i686; rv:38.0) Gecko/20100101 Firefox/38.0
# RUTOR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# =============================================================================
# Kinozal.tv Configuration (REQUIRED)
# =============================================================================
# Russian torrent tracker focused on movies
# Registration required: https://kinozal.tv/signup.php

# Required: Kinozal Login Credentials
KINOZAL_USERNAME=your_kinozal_username
KINOZAL_PASSWORD=your_kinozal_password

# Optional: Use magnet links instead of .torrent files
# Kinozal has download limits, magnet links bypass this
# Default: false
KINOZAL_USE_MAGNET=false

# =============================================================================
# NNM-Club.me Configuration (REQUIRED - Uses Cookies, NOT Password)
# =============================================================================
# One of biggest Russian torrent trackers
# Registration required: https://nnmclub.to/forum/profile.php?mode=register

# Required: NNM-Club Username
NNMCLUB_USERNAME=your_nnmclub_username

# Required: NNM-Club Cookies (NOT password!)
# How to obtain cookies:
#   1. Login to https://nnmclub.to/forum/ in your browser
#   2. Open Developer Tools (F12)
#   3. Go to Network tab
#   4. Refresh the page
#   5. Find any request and copy the Cookie header value
#   6. It should look like: phpbb2mysql_4_sid=abc123; phpbb2mysql_4_data=xyz789
#
# Example format:
NNMCLUB_COOKIES=phpbb2mysql_4_sid=your_sid_here; phpbb2mysql_4_data=your_data_here

# Note: NNM-Club is very sensitive to proxies
# If you get 403 errors, try without proxy first

# =============================================================================
# IPTorrents Configuration (REQUIRED - Private Tracker)
# =============================================================================
# Premium private torrent tracker - Invite only
# Registration: Invite required from existing member

# Required: IPTorrents Login Credentials
IPTORRENTS_USERNAME=your_iptorrents_username
IPTORRENTS_PASSWORD=your_iptorrents_password

# Optional: Custom IPTorrents URL
# Default: https://iptorrents.com
# IPTORRENTS_URL=https://iptorrents.com

# =============================================================================
# Public Trackers Configuration (No Credentials Required)
# =============================================================================
# The following trackers work without authentication:
# - 1337x, ThePirateBay, YTS, EZTV, TorrentGalaxy
# - RARBG Alternative (TheRarBg), ExtraTorrent
# - LimeTorrents, SolidTorrents, TorLock
# - TorrentDownload, TorrentFunk, TorrentProject
# - BT4G, BTSOW, TorrentKitty
# - Nyaa (Anime), AniLibra, Xfsub
# - GamesTorrents, LinuxTracker, PC-Torrents
# - Kickass Torrents, GloTorrents, RockBox
# - Pirateiro, Snowfl, YourBittorrent
# - AcademicTorrents, AudioBook Bay
# - Tokyo Toshokan, Ali213 (Chinese games)

# =============================================================================
# Russian Trackers (No Credentials Required)
# =============================================================================
# The following Russian trackers work without authentication:
# - Rutor, MegaPeer, BitRu

# =============================================================================
# Tracker Mirrors & Custom URLs (Optional)
# =============================================================================
# If main sites are blocked, you can specify custom mirrors:

# 1337x mirror (if default is blocked)
# ONE337X_URL=https://1337x.to

# ThePirateBay mirror (if default is blocked)
# PIRATEBAY_URL=https://thepiratebay.org

# Kickass Torrents mirror
# KICKASS_URL=https://kickasstorrents.to

# ExtraTorrent mirror
# EXTRATORRENT_URL=https://extratorrent.st

# YTS mirror
# YTS_URL=https://yts.mx

# TorrentGalaxy mirror
# TORRENTGALAXY_URL=https://torrentgalaxy.to

# Nyaa mirror (anime)
# NYAA_URL=https://nyaa.si

# =============================================================================
# qBitTorrent Configuration
# =============================================================================
# General qBitTorrent settings

# User/Group IDs (run `id -u` and `id -g` to check)
PUID=1000
PGID=1000

# Timezone
# List of timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Moscow

# WebUI Port
WEBUI_PORT=8085

# WebUI Credentials (change these!)
WEBUI_USERNAME=admin
WEBUI_PASSWORD=admin

# =============================================================================
# Data Directory Configuration
# =============================================================================
# Path where qBitTorrent stores downloads and torrent files
# Can be overridden via environment variable or ~/.bashrc

# Main data directory
QBITTORRENT_DATA_DIR=/mnt/DATA

# Directory structure created automatically:
#   - /DATA                    (main download directory)
#   - /DATA/Incomplete         (incomplete/partial downloads)
#   - /DATA/Torrents/All      (all .torrent files)
#   - /DATA/Torrents/Completed (.torrent files of completed downloads)

# =============================================================================
# Proxy Configuration (Global - applies to all plugins)
# =============================================================================
# Optional: Global proxy settings
# These can be overridden per-plugin above

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# SOCKS_PROXY=socks5://127.0.0.1:1080

# =============================================================================
# Security Notes
# =============================================================================
# 1. This file should have 600 permissions: chmod 600 .env
# 2. Never commit this file to git
# 3. Use strong passwords for tracker accounts
# 4. Consider using a VPN for torrent traffic
# 5. Review tracker terms of service before downloading

# =============================================================================
# Troubleshooting
# =============================================================================
# RuTracker login fails?
#   - Check for CAPTCHA (login via browser first)
#   - Try different mirror
#   - Verify credentials are correct
#
# NNM-Club returns 403?
#   - Very sensitive to proxies - try without proxy
#   - Get fresh cookies from browser
#   - Check if your IP is not banned
#
# Kinozal download limit?
#   - Set KINOZAL_USE_MAGNET=true
#   - Wait for limit to reset
#
# Rutor not working?
#   - Check if rutor.info is accessible
#   - Try rutor.is mirror
#   - No credentials needed!
#
# IPTorrents login fails?
#   - Verify your account is active
#   - Check if you're using the correct URL
#   - Some regions may require VPN
#
# Plugin returns no results?
#   - The site may be down or changed layout
#   - Try a different mirror
#   - Check your internet connection

# =============================================================================
# Testing Configuration
# =============================================================================
# Test your configuration with:
#   ./test.sh --plugin
#   python3 tests/test_all_plugins.py
#   python3 tests/test_plugin_integration.py
#
# Check environment variables in container:
#   podman exec qbittorrent env | grep -E "RUTRACKER|RUTOR|KINOZAL|NNMCLUB|IPTORRENTS"
#
# Test specific plugin:
#   python3 plugins/rutracker.py
#   python3 plugins/iptorrents.py
