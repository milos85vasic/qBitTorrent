%% Graceful shutdown for the qbittorrent-proxy container.
%% Phase 3 target — today the main thread loop is a naive
%% `while True: time.sleep(60)` and SIGTERM kills threads abruptly.
sequenceDiagram
    autonumber
    participant OS as Container runtime (OS)
    participant Main as main.py __main__
    participant Sig as signal handler (SIGTERM/SIGINT)
    participant API as FastAPI app (uvicorn)
    participant ORCH as SearchOrchestrator
    participant Tasks as asyncio.Tasks (in-flight searches)
    participant HTTP as aiohttp.ClientSession pool
    participant T as Daemon threads (proxy + fastapi)

    OS->>Sig: SIGTERM
    Sig->>Main: set _shutting_down = True
    Main->>API: app.state.shutting_down = True
    par fan-in shutdown
        API->>API: reject new POST /search with 503
        API->>Tasks: cancel() all in-flight search tasks
        Tasks-->>API: asyncio.CancelledError (caught in _search_one)
    and
        ORCH->>HTTP: await session.close() for each _tracker_sessions entry
        HTTP-->>ORCH: closed
    end
    API->>API: uvicorn Server.should_exit = True
    API-->>Main: asyncio loop drains (grace 5s)
    Main->>T: thread.join(timeout=5) for each daemon thread
    alt threads joined cleanly
        T-->>Main: return
    else timeout
        Main-->>Main: log "forced shutdown: {thread.name}"
    end
    Main-->>OS: exit 0
