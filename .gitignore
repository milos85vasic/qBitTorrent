# qBittorrent Configuration
config/qBittorrent/
!config/qBittorrent/.gitkeep

# Keep directory structure but ignore all contents
config/qBittorrent/*

# But keep plugin directory structure in git
!config/qBittorrent/nova3/
!config/qBittorrent/nova3/engines/
!config/qBittorrent/nova3/engines/.gitkeep

# Environment files (may contain secrets)
.env
.env.*
*.env
.qbit.env

# NEVER commit credentials - multiple patterns for safety
*credentials*
*secrets*
*_password*
*_passwd*
*_username*
*_user*
RUTRACKER_*

# Log files
*.log
logs/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE/Editor files
.idea/
.vscode/
*.sublime-*
.project
.classpath
.settings/

# Backup files
*.bak
*.backup
*.old

# Downloaded data (if any test downloads)
downloads/
incomplete/

# Podman/Docker volumes (if using local volumes)
volumes/
