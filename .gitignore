# qBittorrent Configuration
config/qBittorrent/
!config/qBittorrent/.gitkeep
!config/qBittorrent/config/
!config/qBittorrent/config/qBittorrent.conf

# Keep directory structure but ignore all contents
config/qBittorrent/*

# But keep plugin directory structure in git
!config/qBittorrent/nova3/
!config/qBittorrent/nova3/engines/
!config/qBittorrent/nova3/engines/.gitkeep

# Environment files (may contain secrets)
.env
.env.*
!.env.example
*.env
.qbit.env

# NEVER commit credentials - multiple patterns for safety
*credentials*
*secrets*
*_password*
*_passwd*
*_username*
*_user*
RUTRACKER_*

# Log files
*.log
logs/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE/Editor files
.idea/
.vscode/
*.sublime-*
.project
.classpath
.settings/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Backup files
*.bak
*.backup
*.old

# Downloaded data (if any test downloads)
downloads/
incomplete/

# Podman/Docker volumes (if using local volumes)
volumes/
config/download-proxy/src/hooks.json

# Ruff cache
.ruff_cache/

# Download-proxy runtime files
config/download-proxy/hooks.json

# Scheduler runtime files
config/merge-service/

# Duplicate source tree (container gets code via volume mount)
config/download-proxy/src/

# Generated reports
plugin_update_report.json
test_report.json
tmp/

# IDE directories
.opencode/
.specify/

# Status/summary markdown (orphaned)
FINAL_STATUS.md
FIXES_SUMMARY.md
FORK_SUMMARY.md
ISSUES_AND_TODOS.md
PLUGIN_STATUS.md
